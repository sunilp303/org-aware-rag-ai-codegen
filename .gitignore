# AI Code Bot - .gitignore

# ============================================================================
# Terraform
# ============================================================================
# Local .terraform directories
**/.terraform/*

# .tfstate files
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.*.log

# Exclude all .tfvars files, which are likely to contain sensitive data
*.tfvars
*.tfvars.json

# Ignore override files as they are usually used to override resources locally
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Include override files you do wish to add to version control using negation pattern
# !example_override.tf

# Include tfplan files to ignore the plan output of command: terraform plan -out=tfplan
*tfplan*

# Ignore CLI configuration files
.terraformrc
terraform.rc

# ============================================================================
# Lambda Packages & Dependencies
# ============================================================================
# Lambda deployment packages
*.zip
lambda_packages/*.zip
lambda/*.zip

# Python dependencies directories
*_deps/
lambda/*_deps/
lambda_dependencies/

# Layer packages
layers/
lambda_layers/

# ============================================================================
# Python
# ============================================================================
# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# C extensions
*.so

# Distribution / packaging
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# PyInstaller
*.manifest
*.spec

# Unit test / coverage reports
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
*.py,cover
.hypothesis/
.pytest_cache/
cover/

# Virtual environments
venv/
ENV/
env/
.venv

# PyCharm
.idea/

# VS Code
.vscode/

# Jupyter Notebook
.ipynb_checkpoints

# pyenv
.python-version

# pipenv
Pipfile.lock

# poetry
poetry.lock

# ============================================================================
# AWS & Secrets
# ============================================================================
# AWS credentials
.aws/
*.pem
*.key
*.crt

# Environment variables
.env
.env.local
.env.*.local

# Secrets files
secrets/
*-secrets.json
*-credentials.json
credentials.json

# AWS SAM
.aws-sam/
samconfig.toml

# ============================================================================
# Bot Temporary Files
# ============================================================================
# GitHub bot temporary files
bot.py
bot_result.json
update.patch

# Lambda test events
event.json
test_event.json

# Temporary code files
temp_code/
scratch/

# ============================================================================
# Documentation Build
# ============================================================================
# Sphinx documentation
docs/_build/
docs/_static/
docs/_templates/

# MkDocs
site/

# ============================================================================
# OS Files
# ============================================================================
# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Linux
*~
.directory
.Trash-*

# ============================================================================
# IDEs and Editors
# ============================================================================
# Visual Studio Code
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
*.code-workspace

# JetBrains IDEs
.idea/
*.iml
*.ipr
*.iws
.idea_modules/

# Sublime Text
*.sublime-project
*.sublime-workspace

# Vim
[._]*.s[a-v][a-z]
[._]*.sw[a-p]
[._]s[a-rt-v][a-z]
[._]ss[a-gi-z]
[._]sw[a-p]

# Emacs
*~
\#*\#
/.emacs.desktop
/.emacs.desktop.lock
*.elc

# ============================================================================
# Logs & Databases
# ============================================================================
# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*

# Local database files
*.db
*.sqlite
*.sqlite3

# ============================================================================
# Node.js (if using for tooling)
# ============================================================================
node_modules/
npm-debug.log
yarn-error.log
package-lock.json
yarn.lock

# ============================================================================
# Project Specific
# ============================================================================
# Backup files
*.backup
*.bak
*.old
*.orig

# Output directories
output/
outputs/
results/

# Test data
test_data/
sample_data/

# Local configuration overrides
local.tf
local.tfvars
config.local.yaml

# Compiled lambda functions (if using other languages)
bootstrap
handler

# DynamoDB local
.dynamodb/

# CloudFormation packaging
packaged.yaml
packaged.json

# ============================================================================
# Documentation & Reports
# ============================================================================
# Generated documentation
*.pdf
*.docx
*.xlsx
!docs/*.pdf
!docs/*.docx

# Reports
reports/
*.html
*.htm
!docs/**/*.html

# ============================================================================
# Security & Compliance
# ============================================================================
# Security scan results
.snyk
snyk-*.json
trivy-*.json
checkov-*.json

# Terraform plan outputs (may contain sensitive data)
plan.out
plan.json

# ============================================================================
# CI/CD
# ============================================================================
# GitHub Actions artifacts
.github/workflows/*.log

# Jenkins
.jenkins/

# GitLab CI
.gitlab-ci-local/

# ============================================================================
# Monitoring & Debugging
# ============================================================================
# Profiling data
*.prof
*.pstats

# Memory dumps
*.hprof
heapdump*

# ============================================================================
# Miscellaneous
# ============================================================================
# Temporary files
tmp/
temp/
*.tmp
*.swp
*.swo

# Archive files (except documentation)
*.tar
*.tar.gz
*.tgz
*.rar
*.7z
!docs/*.tar.gz

# Editor backups
*~
.*.swp
.*.swo

# ============================================================================
# IMPORTANT: Files to KEEP in version control
# ============================================================================
# These are explicitly included (override exclusions above)

# Keep example configuration files
!config.example.yaml
!.env.example
!secrets.example.json

# Keep documentation
!docs/**
!README.md
!CHANGELOG.md
!LICENSE

# Keep GitHub workflows
!.github/workflows/*.yml
!.github/workflows/*.yaml

# Keep Terraform variable definitions
!variables.tf
!outputs.tf

# Keep Lambda function code (not packages)
!lambda/*.py
!lambda/requirements.txt

# Keep documentation images
!docs/images/**
!docs/diagrams/**

# ============================================================================
# Project-Specific Exclusions
# ============================================================================
# Exclude bot result files from GitHub Actions
bot_result_*.json

# Exclude large data files
*.parquet
*.csv
!test_data/*.csv

# Exclude model files if any
models/
*.pkl
*.joblib
*.h5

# Exclude Aurora snapshots if downloaded locally
snapshots/
*.dump
*.sql.gz

# Exclude cost reports
cost_reports/
billing_*.csv
triage.txt
